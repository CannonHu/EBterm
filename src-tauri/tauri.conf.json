{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ebterm",
  "version": "0.1.0",
  "identifier": "com.ebterm.app",
  "build": {
    "beforeDevCommand": "cd /Users/spg/Workspace/Playground/toy_term/frontend && bun run dev",
    "beforeBuildCommand": "cd /Users/spg/Workspace/Playground/toy_term/frontend && bun run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Embedded Debugger",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
